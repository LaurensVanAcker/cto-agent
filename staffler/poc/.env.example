# Copy to .env and fill in real values

# Which Staffler env to talk to. dev | qa | prod
STAFFLER_ENV=qa

# QA gateway is the safest sandbox. Override per env if needed.
STAFFLER_GATEWAY_QA=https://gw.qa.dps.boemm.eu
STAFFLER_GATEWAY_DEV=https://gw.dev.dps.boemm.eu
STAFFLER_GATEWAY_PROD=https://gw.myplanning.digitalpayrollservices.be

# Test account credentials (a COMPANY_USER on a test company in QA)
# Vraag dev-ops voor deze waarden voor je begint.
STAFFLER_USERNAME=
STAFFLER_PASSWORD=

# Port for the local PoC server
PORT=5173
